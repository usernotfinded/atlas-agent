TRADING_MODE=paper
ENABLE_LIVE_TRADING=false
LIVE_BROKER=alpaca
ORDER_APPROVAL_MODE=manual_live
REQUIRE_ORDER_APPROVAL=true

# Risk limits — env values are absolute or direct settings.
# Canonical model defaults live in src/atlas_agent/risk/limits.py:
#   max_position_notional=1000.0  (env: MAX_POSITION_SIZE)
#   max_single_trade_notional=500.0  (env: MAX_ORDER_NOTIONAL)
#   max_daily_loss_pct=0.02  (percentage of equity; env MAX_DAILY_LOSS is absolute $)
#   minimum_confidence=0.6
# The values below are conservative examples; update to match your policy.
MAX_DAILY_LOSS=100
MAX_POSITION_SIZE=100
MAX_TRADES_PER_DAY=5
MAX_PORTFOLIO_EXPOSURE=1000
MAX_ORDER_NOTIONAL=100
MINIMUM_CONFIDENCE=0.6
ALLOW_LEVERAGE=false
KILL_SWITCH_ENABLED=false
REQUIRE_STOP_LOSS_LIVE=true
ENFORCE_MARKET_HOURS=false
SYMBOL_ALLOWLIST=
SYMBOL_BLOCKLIST=
STARTING_CASH=10000
DEFAULT_SYMBOL=
DATA_PATH=data/sample/ohlcv.csv
MEMORY_DIR=memory
AUDIT_DIR=audit
PENDING_ORDERS_DIR=pending_orders
REPORTS_DIR=reports

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Research
ATLAS_RESEARCH_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# ClickUp notifications
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_LIST_ID=
CLICKUP_TASK_ID=

# Git sync for remote routines
ALLOW_GIT_COMMIT=true
ALLOW_GIT_PUSH=false
GIT_COMMIT_AUTHOR_NAME=Atlas Agent
GIT_COMMIT_AUTHOR_EMAIL=atlas-agent@example.local

# Provider adapter
AI_PROVIDER=null
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
LOCAL_COMMAND=

# Broker credentials. Leave blank in committed files.
BINANCE_API_KEY=
BINANCE_API_SECRET=
